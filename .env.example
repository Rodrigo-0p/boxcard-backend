# Environment
NODE_ENV=development
PORT=4000

# Database PostgreSQL (solo configuración del servidor)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=boxcard

# JWT Security
JWT_SECRET=tu_jwt_secret_aqui
ENC_SECRET=tu_enc_secret_aqui
JWT_EXPIRES_IN=8h

# ===========================================================
# CONFIGURACIÓN DE SESIONES (PERSONALIZABLE) INFO CONTACTO
# ===========================================================
DB_INFO_CONTACTO_USER=userinfocontacto
DB_INFO_CONTACTO_PASSWORD=tu_password_aqui


# ===========================================================
# CONFIGURACIÓN DE SESIONES (PERSONALIZABLE) UPDATE PASS
# ===========================================================
DB_USER_UPDATE=userupdatepass
DB_PASS_UPDATE=tu_password_aqui

# ===========================================================
# RATE LIMITING - Protección contra ataques
# ===========================================================
# Login - Intentos de inicio de sesión
# WINDOW = ventana de tiempo en minutos
# MAX_ATTEMPTS = intentos máximos en esa ventana
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5

# Cambio de contraseña
RATE_LIMIT_PASSWORD_WINDOW_MINUTES=15
RATE_LIMIT_PASSWORD_MAX_ATTEMPTS=3

# API General - Requests totales por minuto
# Previene abuso general de la API
RATE_LIMIT_API_WINDOW_MINUTES=1
RATE_LIMIT_API_MAX_REQUESTS=100

# Operaciones sensibles (crear/modificar usuarios, empresas, etc)
# Límite más estricto para operaciones de escritura
RATE_LIMIT_STRICT_WINDOW_MINUTES=1
RATE_LIMIT_STRICT_MAX_OPERATIONS=10
